APP_NAME=Komite API
ENVIRONMENT=production

POSTGRES_DB=komite_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change_me_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=1

NUXT_PUBLIC_API_BASE=https://api.komite.cl

AI_PROVIDER=deepseek
AI_API_KEY=change_me
AI_MODEL=deepseek-v4-flash
AI_BASE_URL=https://api.deepseek.com
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=2000
DEEPSEEK_API_KEY=change_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
TRANSCRIPTION_PROVIDER=local_whisper
LOCAL_WHISPER_MODEL=small
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_DRAFT_MODEL=gpt-5.5
UPLOAD_DIR=storage/uploads
MAX_AUDIO_UPLOAD_MB=25
MAX_EVIDENCE_IMAGE_MB=2
MAX_EVIDENCE_IMAGE_PX=1800
EVIDENCE_IMAGE_QUALITY=82
STORAGE_PROVIDER=s3
STORAGE_PUBLIC_BASE_URL=https://change_me_bucket_public_url
S3_ENDPOINT_URL=https://change_me_region.objectstorage.amazonaws.com
S3_BUCKET=change_me_bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=change_me
S3_SECRET_ACCESS_KEY=change_me
S3_ACL=public-read

TELEGRAM_BOT_TOKEN=change_me

SMTP_HOST=change_me
SMTP_PORT=587
SMTP_USER=change_me
SMTP_PASSWORD=change_me
SMTP_FROM=no-reply@komite.cl

SEED_ADMIN_EMAIL=admin@komite.cl
SEED_ADMIN_PASSWORD=change_me_admin_password
SEED_ADMIN_FULL_NAME=Administrador Komite
